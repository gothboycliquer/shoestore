<Window x:Class="ShoeStore.WPF.Views.ProductListView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Магазин обуви — Список товаров"
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Loaded="Window_Loaded">

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}">
    <Grid Margin="16,0">
        <TextBlock Text="Магазин обуви"
                   Foreground="White"
                   FontSize="20"
                   FontWeight="Bold"
                   VerticalAlignment="Center"/>
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center">
            <TextBlock Text="{Binding WelcomeText}"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="0,0,16,0"/>
            <Button Content="Заказы"
                    Command="{Binding ShowOrdersCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Background="#8E44AD"
                    Margin="0,0,8,0"
                    Visibility="{Binding IsManager, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <Button Content="Выйти"
                    Command="{Binding LogoutCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Background="#E74C3C"/>
        </StackPanel>
    </Grid>
</Border>

        
<Border Grid.Row="1"
            Background="White"
            Padding="16,12">
    <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource ModernTextBoxStyle}"
                        Margin="0,0,12,0"
                        Visibility="{Binding IsManager, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <ComboBox Grid.Column="1"
                        ItemsSource="{Binding Suppliers}"
                        SelectedItem="{Binding SelectedSupplier}"
                        DisplayMemberPath="Name"
                        Padding="10,8"
                        FontSize="14"
                        Margin="0,0,12,0"
                        Visibility="{Binding IsManager, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <Button Grid.Column="2"
                        Content="↑ Кол-во"
                        Command="{Binding SortByQuantityAscCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Background="#27AE60"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="3"
                        Content="↓ Кол-во"
                        Command="{Binding SortByQuantityDescCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Background="#E67E22"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="4"
                        Content="↑ Цена"
                        Command="{Binding SortByPriceAscCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Background="#2980B9"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="5"
                        Content="↓ Цена"
                        Command="{Binding SortByPriceDescCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Background="#8E44AD"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="6"
                        Content="+ Добавить товар"
                        Command="{Binding AddProductCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibilityConverter}}"/>
    </Grid>
</Border>

        
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding ProductsView}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Margin="16"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="220"
                                Margin="8"
                                CornerRadius="8"
                                BorderThickness="1"
                                BorderBrush="#E0E0E0">
                            <Border.Background>
                            <Binding Path="Discount" Converter="{StaticResource DiscountToBackgroundConverter}"/>
                            </Border.Background>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Quantity}" Value="0">
                                            <Setter Property="Background" Value="#ADD8E6"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <StackPanel>
                                <Image Height="150"
                                       Stretch="UniformToFill"
                                       Source="{Binding ImagePath, Converter={StaticResource NullToPlaceholderConverter}}"
                                       ClipToBounds="True"/>

                                <StackPanel Margin="12,8">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="Bold"
                                               FontSize="14"
                                               TextWrapping="Wrap"/>

                                    <TextBlock Text="{Binding CategoryName}"
                                               Foreground="Gray"
                                               FontSize="12"
                                               Margin="0,2,0,0"/>

                                    <TextBlock Text="{Binding ManufacturerName}"
                                               Foreground="Gray"
                                               FontSize="12"/>

                                    <TextBlock Text="{Binding Description}"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Foreground="#555"
                                               Margin="0,4,0,4"
                                               MaxHeight="40"/>

                                    
                                    <TextBlock Visibility="{Binding Discount, Converter={StaticResource DiscountVisibilityConverter}}">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0:N2} ₽">
                                                <Binding Path="Price"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                        <TextBlock.TextDecorations>
                                            <TextDecoration Location="Strikethrough"/>
                                        </TextBlock.TextDecorations>
                                        <TextBlock.Foreground>
                                            <SolidColorBrush Color="Red"/>
                                        </TextBlock.Foreground>
                                    </TextBlock>

                                    
                                    <TextBlock FontWeight="Bold" FontSize="16">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource PriceWithDiscountConverter}">
                                                <Binding Path="Price"/>
                                                <Binding Path="Discount"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>

                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="Кол-во: " FontSize="12"/>
                                        <TextBlock Text="{Binding Quantity}" FontSize="12" FontWeight="Bold"/>
                                        <TextBlock Text=" " FontSize="12"/>
                                        <TextBlock Text="{Binding Unit}" FontSize="12"/>
                                    </StackPanel>

                                    <TextBlock Foreground="Green"
           FontSize="12">
    <TextBlock.Visibility>
        <Binding Path="Discount" Converter="{StaticResource DiscountVisibilityConverter}"/>
    </TextBlock.Visibility>
    <Run Text="Скидка: "/>
    <Run Text="{Binding Discount, StringFormat={}{0}%}"/>
</TextBlock>

                                    
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,8,0,0"
                                                Visibility="{Binding DataContext.IsAdmin, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Button Content="Изменить"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Command="{Binding DataContext.EditProductCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Padding="8,4"
                                                FontSize="12"
                                                Margin="0,0,4,0"/>
                                        <Button Content="Удалить"
                                                Style="{StaticResource DangerButtonStyle}"
                                                Command="{Binding DataContext.DeleteProductCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Padding="8,4"
                                                FontSize="12"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="#80000000"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="Загрузка..."
                       Foreground="White"
                       FontSize="20"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>