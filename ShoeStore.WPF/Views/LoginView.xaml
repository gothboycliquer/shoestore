<Window x:Class="ShoeStore.WPF.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Магазин обуви — Вход"
        Height="560" Width="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#F5F6FA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="140"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="👟"
                           FontSize="40"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Магазин обуви"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="40,32,40,40">
            <TextBlock Text="Логин" Margin="0,0,0,6" FontWeight="SemiBold"/>
            <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ModernTextBoxStyle}"
                     Margin="0,0,0,16"/>

            <TextBlock Text="Пароль" Margin="0,0,0,6" FontWeight="SemiBold"/>
            <PasswordBox x:Name="PasswordBox"
                         Style="{StaticResource ModernPasswordBoxStyle}"
                         PasswordChanged="PasswordBox_PasswordChanged"
                         Margin="0,0,0,8"/>

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#E74C3C"
                       Margin="0,0,0,16"
                       TextWrapping="Wrap"
                       MinHeight="20"/>

            <Button Content="Войти"
                    Command="{Binding LoginCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Height="42"
                    FontSize="15"
                    Margin="0,0,0,10"/>

            <Button Content="Войти как гость"
                    Command="{Binding GuestCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Height="42"
                    FontSize="15"
                    Background="#95A5A6"/>
        </StackPanel>
    </Grid>
</Window>