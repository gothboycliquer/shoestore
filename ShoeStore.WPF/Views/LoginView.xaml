<Window x:Class="ShoeStore.WPF.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему"
        Height="400" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Background="{StaticResource BackgroundBrush}">
        <StackPanel VerticalAlignment="Center" Margin="40">
            <TextBlock Text="Магазин обуви"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30"/>

            <TextBlock Text="Логин" Margin="0,0,0,4"/>
            <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ModernTextBoxStyle}"
                     Margin="0,0,0,16"/>

            <TextBlock Text="Пароль" Margin="0,0,0,4"/>
            <PasswordBox x:Name="PasswordBox"
             Style="{StaticResource ModernPasswordBoxStyle}"
             PasswordChanged="PasswordBox_PasswordChanged"
             Margin="0,0,0,8"/>

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource DangerBrush}"
                       Margin="0,0,0,16"
                       TextWrapping="Wrap"/>

            <Button Content="Войти"
                    Command="{Binding LoginCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Margin="0,0,0,8"/>

            <Button Content="Войти как гость"
                    Command="{Binding GuestCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Background="#95A5A6"/>
        </StackPanel>
    </Grid>
</Window>